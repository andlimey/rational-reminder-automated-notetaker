# Required: Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Required: recipient for notes emails
NOTES_EMAIL_TO=your@email.com

# Resend (https://resend.com) – required for sending email
RESEND_API_KEY=re_your_api_key
# Optional: sender address (default: onboarding@resend.dev for testing; use verified domain in production)
# RESEND_FROM=Notes <notes@yourdomain.com>

# Optional: set to true to return test notes instead of calling Gemini (for development)
# RETURN_TEST_NOTES=true
